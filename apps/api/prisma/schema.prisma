generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  ADMIN
  SUB_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
  FREELANCE
}

enum VisaPolicy {
  VISA_PROVIDED
  TRANSFER_AVAILABLE
  NOT_PROVIDED
  NOT_REQUIRED
}

enum JobStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  PAUSED
  CLOSED
  EXPIRED
  REJECTED
}

enum EmployerVerifiedStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  VIEWED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model User {
  id            String          @id @default(uuid())
  role          UserRole
  email         String          @unique
  phone         String?
  passwordHash  String
  status        UserStatus      @default(ACTIVE)
  verifiedAt    DateTime?
  lastLoginAt   DateTime?
  twoFaEnabled  Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  jobSeekerProfile JobSeekerProfile?
  resumes          Resume[]
  employerOwned    Employer[]       @relation("EmployerOwner")
  employerMemberships EmployerMember[]
  applications     Application[]
  sentMessages     Message[]        @relation("MessageFrom")
  receivedMessages Message[]        @relation("MessageTo")
  notifications    Notification[]
  reports          Report[]         @relation("Reporter")
  refreshTokens    RefreshToken[]
  auditActions     AuditLog[]       @relation("AuditActor")
}

model JobSeekerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  fullName         String?
  emirate          String?
  locationText     String?
  desiredRole      String?
  expectedSalary   Int?
  workModePrefs    String[]
  skills           String[]
  certifications   String[]
  portfolioLinks   String[]
  linkedinUrl      String?
  noticePeriodDays Int?
  immediateJoiner  Boolean  @default(false)
  preferencesJson  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  fileUrl    String
  parsedText String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Employer {
  id              String               @id @default(uuid())
  ownerUserId     String
  companyName     String
  industry        String?
  description     String?
  website         String?
  logoUrl         String?
  tradeLicenseUrl String?
  verifiedStatus  EmployerVerifiedStatus @default(PENDING)
  verificationNote String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  ownerUser   User               @relation("EmployerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     EmployerMember[]
  jobs        Job[]
  subscription Subscription?

  @@index([verifiedStatus])
}

model EmployerMember {
  id         String   @id @default(uuid())
  employerId String
  userId     String
  role       String
  createdAt  DateTime @default(now())

  employer Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([employerId, userId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  parentId  String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  jobs     Job[]

  @@index([parentId, sortOrder])
}

model Job {
  id                  String          @id @default(uuid())
  employerId          String
  title               String
  slug                String          @unique
  description         String
  requirements        String?
  benefits            String[]
  categoryId          String
  emirate             String
  locationText        String
  salaryMin           Int?
  salaryMax           Int?
  currency            String          @default("AED")
  negotiable          Boolean         @default(false)
  experienceMin       Int?
  experienceMax       Int?
  experienceBand      String?
  workMode            WorkMode
  employmentType      EmploymentType
  visa                VisaPolicy
  immediateJoiner     Boolean         @default(false)
  languageRequirements String[]
  skills              String[]
  status              JobStatus       @default(DRAFT)
  featuredUntil       DateTime?
  urgent              Boolean         @default(false)
  expiresAt           DateTime?
  viewsCount          Int             @default(0)
  appliesCount        Int             @default(0)
  moderationFlags     String[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  employer           Employer            @relation(fields: [employerId], references: [id], onDelete: Cascade)
  category           Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  screeningQuestions ScreeningQuestion[]
  applications       Application[]

  @@index([categoryId])
  @@index([emirate])
  @@index([status, createdAt])
  @@index([salaryMin, salaryMax])
}

model ScreeningQuestion {
  id        String   @id @default(uuid())
  jobId     String
  question  String
  type      String
  options   String[]
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Application {
  id          String            @id @default(uuid())
  jobId        String
  userId       String
  status       ApplicationStatus @default(SUBMITTED)
  cvId         String?
  coverLetter  String?
  answersJson  Json?
  notes        String?
  rating       Int?
  tags         String[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([status])
}

model Message {
  id         String   @id @default(uuid())
  threadId   String
  fromUserId String
  toUserId   String
  body       String
  createdAt  DateTime @default(now())

  fromUser User @relation("MessageFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("MessageTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Notification {
  id          String   @id @default(uuid())
  userId       String
  type         String
  payloadJson  Json
  readAt       DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Report {
  id          String       @id @default(uuid())
  type        String
  reporterId  String
  targetType  String
  targetId    String
  reason      String
  status      ReportStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model Subscription {
  id               String   @id @default(uuid())
  employerId        String   @unique
  plan              String
  provider          String
  providerSubId     String?
  status            String
  quotaJobPosts     Int      @default(3)
  quotaFeatured     Int      @default(0)
  candidateSearch   Boolean  @default(false)
  currentPeriodEnd  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employer Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorRole   String
  action      String
  targetType  String
  targetId    String?
  metaJson    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
