# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT — copy this to .env.production and fill in all values
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=uaejobs
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=uaejobsdb

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Must match POSTGRES credentials above
DATABASE_URL=postgresql://uaejobs:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/uaejobsdb

REDIS_URL=redis://redis:6379

# ── JWT Secrets (generate with: openssl rand -hex 64) ─────────────────────────
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64_AGAIN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS / Frontend URL ───────────────────────────────────────────────────────
# Your domain or server IP
FRONTEND_URL=https://yourdomain.com
WEB_URL=https://yourdomain.com

# ── File Storage ──────────────────────────────────────────────────────────────
# Use 'local' or 's3'
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3/MinIO (only needed if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-central-1
AWS_BUCKET=uaejobs-uploads
AWS_ENDPOINT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com

# ── Billing ───────────────────────────────────────────────────────────────────
# Use 'mock' for testing or 'stripe' for real payments
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── WhatsApp / Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://yourdomain.com/api/v1/whatsapp/webhook

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Features ─────────────────────────────────────────────────────────────────
ENABLE_MESSAGING=true
REQUIRE_EMPLOYER_VERIFICATION_FOR_PUBLISH=true

# ── Admin Seed Account ────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
