{
  "name": "uae-job-portal",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c red,blue \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @uaejobs/api",
    "dev:web": "npm run dev -w @uaejobs/web",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "test": "npm run test -ws",
    "seed": "npm run seed -w @uaejobs/api",
    "migrate": "npm run prisma:deploy -w @uaejobs/api",
    "studio": "npm run prisma:studio -w @uaejobs/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express-serve-static-core": "^4.19.8",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
