generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SEEKER
  EMPLOYER
  ADMIN
  SUB_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum Emirates {
  ABU_DHABI
  DUBAI
  SHARJAH
  AJMAN
  UMM_AL_QUWAIN
  RAS_AL_KHAIMAH
  FUJAIRAH
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
  FREELANCE
}

enum VisaStatus {
  PROVIDED
  TRANSFER_AVAILABLE
  NOT_PROVIDED
  NOT_REQUIRED
}

enum JobStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  PAUSED
  EXPIRED
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  VIEWED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  JOB
  EMPLOYER
  USER
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  phone            String?
  passwordHash     String?    @db.Text
  role             UserRole   @default(SEEKER)
  status           UserStatus @default(PENDING_VERIFICATION)
  verifiedAt       DateTime?
  lastLoginAt      DateTime?
  twoFactorEnabled Boolean    @default(false)
  emailOtp         String?
  emailOtpExpiry   DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?

  // Social auth
  socialProvider   String?
  socialId         String?
  avatarUrl        String?    @db.Text
  displayName      String?

  refreshTokens       RefreshToken[]
  seekerProfile       JobSeekerProfile?
  employerMemberships EmployerMember[]
  ownedEmployer       Employer?          @relation("EmployerOwner")
  applications        Application[]
  savedJobs           SavedJob[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  sentReports         Report[]           @relation("ReporterUser")
  auditActions        AuditLog[]         @relation("AuditActor")
  messagesFrom        Message[]          @relation("MessageFrom")
  messagesTo          Message[]          @relation("MessageTo")
  cvProfile           CVProfile?
  cvAnalyses          CVAnalysis[]
  whatsappSession     WhatsAppSession?
  companyReviews      CompanyReview[]   @relation("ReviewAuthor")
  savedByEmployers    CandidateSave[]   @relation("SavedCandidate")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@unique([socialProvider, socialId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(512)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Seeker profile ───────────────────────────────────────────────────────────

model JobSeekerProfile {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  headline          String?    @db.Text
  bio               String?    @db.Text
  emirate           Emirates?
  location          String?
  nationality       String?
  dateOfBirth       DateTime?
  gender            String?
  desiredRole       String?
  desiredSalaryMin  Int?
  desiredSalaryMax  Int?
  desiredWorkModes  Json       @default("[]")
  desiredEmirates   Json       @default("[]")
  yearsOfExperience Int?
  currentSalary     Int?
  noticePeriod      String?
  immediateJoiner   Boolean    @default(false)
  languages         Json       @default("[]")
  skills            Json       @default("[]")
  linkedInUrl       String?    @db.Text
  portfolioUrl      String?    @db.Text
  avatarUrl         String?    @db.Text
  isProfilePublic   Boolean    @default(true)

  resumes        Resume[]
  education      Education[]
  experience     WorkExperience[]
  certifications Certification[]
  jobAlerts      JobAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id          String           @id @default(cuid())
  profileId   String
  profile     JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String           @db.Text
  fileSize    Int
  mimeType    String
  isPrimary   Boolean          @default(false)
  parsedText  String?          @db.LongText
  applications Application[]

  createdAt DateTime @default(now())

  @@index([profileId])
}

model Education {
  id           String           @id @default(cuid())
  profileId    String
  profile      JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution  String
  degree       String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean          @default(false)
  description  String?          @db.Text
  createdAt    DateTime         @default(now())
}

model WorkExperience {
  id          String           @id @default(cuid())
  profileId   String
  profile     JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  title       String
  emirate     Emirates?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean          @default(false)
  description String?          @db.Text
  skills      Json             @default("[]")
  createdAt   DateTime         @default(now())
}

model Certification {
  id            String           @id @default(cuid())
  profileId     String
  profile       JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name          String
  issuingOrg    String
  issueDate     DateTime?
  expiryDate    DateTime?
  credentialUrl String?          @db.Text
  createdAt     DateTime         @default(now())
}

// ─── Employers ────────────────────────────────────────────────────────────────

model Employer {
  id                 String             @id @default(cuid())
  ownerUserId        String             @unique
  owner              User               @relation("EmployerOwner", fields: [ownerUserId], references: [id])
  companyName        String
  slug               String             @unique
  industry           String?
  companySize        String?
  foundedYear        Int?
  description        String?            @db.Text
  website            String?            @db.Text
  logoUrl            String?            @db.Text
  coverUrl           String?            @db.Text
  emirate            Emirates?
  location           String?
  tradeLicenseUrl    String?            @db.Text
  tradeLicenseNumber String?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  verificationNotes  String?            @db.Text
  isActive           Boolean            @default(true)

  members         EmployerMember[]
  jobs            Job[]
  subscription    Subscription?
  reviews         CompanyReview[]
  savedCandidates CandidateSave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([verificationStatus])
}

model EmployerMember {
  id         String    @id @default(cuid())
  employerId String
  employer   Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String    @default("RECRUITER")
  invitedAt  DateTime  @default(now())
  joinedAt   DateTime?

  @@unique([employerId, userId])
  @@index([employerId])
  @@index([userId])
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  parentId   String?
  parent     Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryParent")
  sortOrder  Int        @default(0)
  isActive   Boolean    @default(true)
  isFeatured Boolean    @default(false)
  iconUrl    String?    @db.Text
  jobs       Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id               String         @id @default(cuid())
  employerId       String
  employer         Employer       @relation(fields: [employerId], references: [id])
  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id])
  title            String
  slug             String         @unique
  shortCode        String?        @unique
  description      String         @db.LongText
  requirements     String?        @db.Text
  benefits         String?        @db.Text
  emirate          Emirates
  location         String?
  workMode         WorkMode       @default(ONSITE)
  employmentType   EmploymentType @default(FULL_TIME)
  visaStatus       VisaStatus     @default(NOT_PROVIDED)
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String         @default("AED")
  salaryNegotiable Boolean        @default(false)
  experienceMin    Int            @default(0)
  experienceMax    Int?
  level            String?
  skills           Json           @default("[]")
  languages        Json           @default("[]")
  status           JobStatus      @default(DRAFT)
  isFeatured       Boolean        @default(false)
  isUrgent         Boolean        @default(false)
  isEmiratization  Boolean        @default(false)
  fraudRiskScore   Int?
  fraudRiskLevel   String?
  fraudFlags       Json?
  fraudExplanation String?        @db.Text
  fraudCheckedAt   DateTime?
  featuredUntil    DateTime?
  publishedAt      DateTime?
  expiresAt        DateTime?
  viewCount        Int            @default(0)
  applyCount       Int            @default(0)
  moderationNotes  String?        @db.Text
  metaTitle        String?
  metaDescription  String?        @db.Text

  tags               JobTag[]
  screeningQuestions ScreeningQuestion[]
  applications       Application[]
  savedBy            SavedJob[]
  reports            Report[]            @relation("JobReport")
  socialShares       SocialShareClick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employerId])
  @@index([categoryId])
  @@index([status])
  @@index([emirate])
  @@index([workMode])
  @@index([employmentType])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([isFeatured])
  @@index([isEmiratization])
  @@index([fraudRiskLevel])
  @@index([shortCode])
}

model Tag {
  id   String   @id @default(cuid())
  name String   @unique
  jobs JobTag[]
}

model JobTag {
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
}

model ScreeningQuestion {
  id        String  @id @default(cuid())
  jobId     String
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question  String  @db.Text
  type      String
  options   Json    @default("[]")
  required  Boolean @default(false)
  sortOrder Int     @default(0)
}

// ─── Applications ─────────────────────────────────────────────────────────────

model Application {
  id            String            @id @default(cuid())
  jobId         String
  job           Job               @relation(fields: [jobId], references: [id])
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  resumeId      String?
  resume        Resume?           @relation(fields: [resumeId], references: [id])
  coverLetter   String?           @db.Text
  answersJson   Json?
  status        ApplicationStatus @default(SUBMITTED)
  notes         String?           @db.Text
  rating        Int?
  tags          Json              @default("[]")
  interviewDate DateTime?

  interviewSlots  InterviewSlot[]
  screeningResult AIScreeningResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AIScreeningResult {
  id                String      @id @default(cuid())
  applicationId     String      @unique
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobId             String
  fitScore          Int
  fitLabel          String
  priority          String
  matchingStrengths Json        @default("[]")
  gaps              Json        @default("[]")
  recommendation    String      @db.Text
  screenedAt        DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([jobId])
}

model SavedJob {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, jobId])
}

model JobAlert {
  id         String           @id @default(cuid())
  profileId  String
  profile    JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  keywords   String?
  categoryId String?
  emirate    Emirates?
  workMode   WorkMode?
  salaryMin  Int?
  frequency  String           @default("WEEKLY")
  isActive   Boolean          @default(true)
  lastSentAt DateTime?
  createdAt  DateTime         @default(now())
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Message {
  id         String    @id @default(cuid())
  threadId   String
  fromUserId String
  from       User      @relation("MessageFrom", fields: [fromUserId], references: [id])
  toUserId   String
  to         User      @relation("MessageTo", fields: [toUserId], references: [id])
  body       String    @db.Text
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([threadId])
  @@index([fromUserId])
  @@index([toUserId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String?   @db.Text
  payloadJson Json?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([readAt])
}

// ─── Reports ──────────────────────────────────────────────────────────────────

model Report {
  id             String           @id @default(cuid())
  reporterId     String
  reporter       User             @relation("ReporterUser", fields: [reporterId], references: [id])
  targetType     ReportTargetType
  targetId       String
  job            Job?             @relation("JobReport", fields: [targetId], references: [id])
  reason         String
  details        String?          @db.Text
  status         ReportStatus     @default(PENDING)
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?          @db.Text
  createdAt      DateTime         @default(now())

  @@index([targetType, targetId])
  @@index([status])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  employerId             String             @unique
  employer               Employer           @relation(fields: [employerId], references: [id])
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  provider               String             @default("mock")
  providerSubId          String?
  jobPostsLimit          Int                @default(3)
  jobPostsUsed           Int                @default(0)
  featuredPostsLimit     Int                @default(0)
  candidateSearchEnabled Boolean            @default(false)
  currentPeriodStart     DateTime           @default(now())
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  metaJson    Json?
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

// ─── ATS / CV ─────────────────────────────────────────────────────────────────

model CVProfile {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                String?
  targetRole           String?
  professionalSummary  String?  @db.Text
  skills               Json     @default("[]")
  languages            Json     @default("[]")
  cvDataJson           Json?

  analyses CVAnalysis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CVAnalysis {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvProfileId String?
  cvProfile   CVProfile? @relation(fields: [cvProfileId], references: [id])

  jobTitle        String?
  companyName     String?
  jobDescription  String?  @db.Text
  cvText          String   @db.LongText

  atsScore          Int
  keywordMatchScore Int
  formatScore       Int
  contentScore      Int

  matchedKeywords  Json     @default("[]")
  missingKeywords  Json     @default("[]")
  strengths        Json     @default("[]")
  weaknesses       Json     @default("[]")
  suggestionsJson  Json?
  summary          String?  @db.Text

  coverLetter      String?  @db.LongText
  interviewQsJson  Json?

  aiModel         String   @default("claude-sonnet-4-6")
  analysisType    String   @default("ats")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Social / SEO ─────────────────────────────────────────────────────────────

model SocialShareClick {
  id          String   @id @default(cuid())
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  platform    String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?  @db.Text
  userAgent   String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([jobId])
  @@index([platform])
  @@index([createdAt])
}

// ─── WhatsApp Chatbot ─────────────────────────────────────────────────────────

model WhatsAppSession {
  id           String   @id @default(cuid())
  phoneNumber  String   @unique
  waId         String?
  profileName  String?
  state        String   @default("idle")
  contextJson  Json?
  optedOut     Boolean  @default(false)
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([phoneNumber])
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  sessionId  String?
  messageSid String?  @unique
  from       String
  to         String
  body       String   @db.Text
  direction  String
  status     String   @default("received")
  mediaUrl   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([from])
  @@index([sessionId])
  @@index([createdAt])
}

// ─── Company Reviews ──────────────────────────────────────────────────────────

model CompanyReview {
  id               String   @id @default(cuid())
  employerId       String
  employer         Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  reviewerId       String
  reviewer         User     @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  title            String
  pros             String   @db.Text
  cons             String   @db.Text
  rating           Int
  workLifeBalance  Int
  salaryBenefits   Int
  management       Int
  careerGrowth     Int
  jobTitle         String?
  employmentStatus String   @default("CURRENT")
  isAnonymous      Boolean  @default(true)
  isVerified       Boolean  @default(false)
  helpfulCount     Int      @default(0)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([employerId, reviewerId])
  @@index([employerId])
  @@index([status])
  @@index([rating])
}

// ─── Salary Data ──────────────────────────────────────────────────────────────

model SalaryData {
  id            String    @id @default(cuid())
  jobTitle      String
  industry      String?
  emirate       Emirates?
  experienceMin Int       @default(0)
  experienceMax Int?
  salaryMin     Int
  salaryMax     Int
  currency      String    @default("AED")
  source        String    @default("user")
  userId        String?
  isAnonymous   Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([jobTitle])
  @@index([emirate])
  @@index([industry])
}

// ─── Candidate Saves ──────────────────────────────────────────────────────────

model CandidateSave {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  seekerId   String
  seeker     User     @relation("SavedCandidate", fields: [seekerId], references: [id], onDelete: Cascade)
  notes      String?  @db.Text
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())

  @@unique([employerId, seekerId])
  @@index([employerId])
}

// ─── Interview Slots ──────────────────────────────────────────────────────────

model InterviewSlot {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  durationMins  Int         @default(60)
  type          String      @default("VIDEO")
  meetingLink   String?     @db.Text
  location      String?
  notes         String?     @db.Text
  status        String      @default("PROPOSED")
  proposedBy    String
  confirmedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([scheduledAt])
}

// ─── CMS ──────────────────────────────────────────────────────────────────────

model ContentPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   @db.LongText
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  content     String    @db.LongText
  coverImage  String?   @db.Text
  author      String    @default("Admin")
  category    String    @default("General")
  tags        Json      @default("[]")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  readTime    Int?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished, publishedAt])
}

model UsefulLink {
  id          String   @id @default(cuid())
  title       String
  url         String   @db.Text
  description String?  @db.Text
  category    String   @default("General")
  iconUrl     String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isActive])
}

model WhatsAppGroup {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  link        String   @db.Text
  category    String   @default("General")
  emoji       String   @default("💬")
  memberCount Int?
  maxMembers  Int?
  isPinned    Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  clickCount  Int      @default(0)
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isActive])
  @@index([isPinned, sortOrder])
}

model WhatsAppLinksPage {
  id          String  @id @default("main")
  name        String  @default("Join Our WhatsApp Groups")
  tagline     String?
  bio         String? @db.Text
  avatarUrl   String? @db.Text
  bannerText  String? @db.Text
  bannerColor String  @default("#10b981")
  theme       String  @default("emerald")
  socialLinks Json?
  isPublished Boolean @default(true)
  showStats   Boolean @default(true)
  updatedAt   DateTime @updatedAt
}

// ── Community Discussions ────────────────────────────────────────────────────

enum DiscussionStatus {
  PENDING
  APPROVED
  CLOSED
  REMOVED
}

model Discussion {
  id          String           @id @default(cuid())
  title       String
  body        String           @db.Text
  category    String           @default("GENERAL")
  tags        Json             @default("[]")
  status      DiscussionStatus @default(PENDING)
  isPinned    Boolean          @default(false)
  isAnonymous Boolean          @default(false)
  viewCount   Int              @default(0)
  upvoteCount Int              @default(0)
  replyCount  Int              @default(0)
  isAnswered  Boolean          @default(false)
  authorId    String?
  authorName  String?
  authorEmail String?
  authorIp    String?
  adminNote   String?          @db.Text
  pinnedAt    DateTime?
  closedAt    DateTime?
  replies     DiscussionReply[]
  votes       DiscussionVote[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category, status])
  @@index([isPinned, status])
  @@index([status, createdAt])
}

model DiscussionReply {
  id           String     @id @default(cuid())
  body         String     @db.Text
  isAccepted   Boolean    @default(false)
  isAdminReply Boolean    @default(false)
  isAnonymous  Boolean    @default(false)
  upvoteCount  Int        @default(0)
  authorId     String?
  authorName   String?
  authorEmail  String?
  authorIp     String?
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  votes        DiscussionReplyVote[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([discussionId])
}

model DiscussionVote {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  voterIp      String
  createdAt    DateTime   @default(now())

  @@unique([discussionId, voterIp])
}

model DiscussionReplyVote {
  id        String          @id @default(cuid())
  replyId   String
  reply     DiscussionReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  voterIp   String
  createdAt DateTime        @default(now())

  @@unique([replyId, voterIp])
}

model CommunitySettings {
  id                String  @id @default("main")
  whatsappNumber    String?
  whatsappGroupLink String? @db.Text
  contactEmail      String?
  telegramLink      String? @db.Text
  bannerText        String? @db.Text
  bannerEnabled     Boolean @default(false)
  requireModeration Boolean @default(true)
  allowAnonymous    Boolean @default(true)
  updatedAt         DateTime @updatedAt
}


// ── Mobile push notification device tokens ────────────────────────────────────
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @db.VarChar(512)
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}
