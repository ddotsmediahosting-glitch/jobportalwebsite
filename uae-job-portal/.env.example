# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uaejobs

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_key_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@uaejobs.local

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 (used when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-central-1
AWS_BUCKET=uaejobs-uploads
AWS_ENDPOINT=                   # optional, for S3-compatible providers

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Options: mock | stripe
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# ─── Admin seed account ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@uaejobs.local
SEED_ADMIN_PASSWORD=Admin#12345

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
